{
  "name": "@taeyoung1005/shellmates",
  "version": "0.1.2",
  "description": "Open-source human-to-human social matching for Claude Code, with local agent-assisted profiles, encrypted 1:1 chat, and a context firewall.",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "shellmates": "dist/src/cli/cli.js",
    "sm": "dist/src/cli/cli.js",
    "sm-daemon": "dist/src/daemon/daemon.js",
    "sm-mcp": "dist/src/mcp/server.js",
    "sm-mcp-full": "dist/src/mcp/full.js",
    "sm-channel": "dist/src/channel/server.js",
    "sm-relay": "dist/src/server/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "cli": "tsx src/cli/cli.ts",
    "daemon": "tsx src/daemon/daemon.ts",
    "mcp": "tsx src/mcp/server.ts",
    "mcp:full": "tsx src/mcp/full.ts",
    "channel": "tsx src/channel/server.ts",
    "server": "tsx src/server/server.ts",
    "demo": "tsx src/demo/demo.ts",
    "demo:net": "tsx src/demo/demo-net.ts",
    "clean": "rm -rf dist",
    "setup-shellmates": "bash scripts/setup-shellmates.sh",
    "install-agent": "bash scripts/install-agent.sh",
    "worker:deploy": "cd worker && wrangler deploy --x-autoconfig=false"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
