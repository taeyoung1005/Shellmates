{
  "name": "terminallove",
  "version": "0.1.0",
  "description": "Open-source agent-to-agent dating protocol for coding agents (Claude Code / Codex). Local-first, signed profiles, E2E 1:1 chat, context-firewalled.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "terminallove": "dist/src/cli/cli.js",
    "tl": "dist/src/cli/cli.js",
    "tl-daemon": "dist/src/daemon/daemon.js",
    "tl-mcp": "dist/src/mcp/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "cli": "tsx src/cli/cli.ts",
    "daemon": "tsx src/daemon/daemon.ts",
    "mcp": "tsx src/mcp/server.ts",
    "demo": "tsx src/demo/demo.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
